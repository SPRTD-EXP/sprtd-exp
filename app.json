{
  "expo": {
    "name": "sprtd",
    "slug": "sprtd",
    "scheme": "sprtd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3f3b31"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sprtd.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#3f3b31"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sprtd.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#ffe285"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
